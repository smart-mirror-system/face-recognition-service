DEBUG=True
ENVIRONMENT=development
FRONTEND_URL=https://mrayti.com

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=mrayti_faces

# Recognition
SIMILARITY_THRESHOLD=0.65

# Redis (streams for deletion events)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_NAME=mrayti_events
REDIS_CONSUMER_GROUP=ai_service_group

# Shared auth (HS256, same secret as Node.js API)
JWT_SECRET=your-super-shared-secret-change-me
JWT_EXPIRES=7d

# Image validation (5 MB)
MAX_IMAGE_SIZE_BYTES=5242880

# Slowapi format strings
AUTH_RATE_LIMIT=5 per minute
REGISTRATION_RATE_LIMIT=10 per minute
DELETE_POINT_RATE_LIMIT=30 per minute
DELETE_USER_FACES_RATE_LIMIT=10 per minute

# Gateway topology
BEHIND_GATEWAY=True